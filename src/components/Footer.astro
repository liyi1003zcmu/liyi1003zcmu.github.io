---
import { siteConfig } from '@/config/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h2>{siteConfig.shortName}</h2><p>{siteConfig.description}</p><p class="muted">
        本站使用Astro构建，运行于github pages。
      </p>
    </div><div>
      <h2>联系与链接</h2><p>作者：{siteConfig.author}</p>{
        siteConfig.email && (
          <p>
            <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
          </p>
        )
      }<p>
        <a href={siteConfig.githubProfile} target="_blank" rel="noopener noreferrer"
          >GitHub 主页（外部链接）</a
        >
      </p><p>© {year}</p>
    </div>
  </div>
</footer>
