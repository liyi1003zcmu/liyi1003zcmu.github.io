---
import type { CollectionEntry } from 'astro:content';
import TagList from './TagList.astro';
interface Props {
  resource: CollectionEntry<'resources'>;
}
const { resource } = Astro.props;
const hasFile = Boolean(resource.data.fileUrl && resource.data.downloadable);
const hasExternal = Boolean(resource.data.externalUrl);
---

<article
  class="resource-item"
  data-resource
  data-course={resource.data.course}
  data-type={resource.data.resourceType}
  data-chapter={resource.data.chapter}
  data-tags={resource.data.tags.join('|')}
  data-pagefind-filter="type:资源"
>
  <p class="eyebrow">{resource.data.resourceType} · {resource.data.course}</p><h2>
    {resource.data.title}
  </h2><p>{resource.data.description}</p><p class="card-meta">
    章节：{resource.data.chapter}{resource.data.fileFormat && ` · ${resource.data.fileFormat}`}{
      resource.data.fileSize && ` · ${resource.data.fileSize}`
    } · 版本 {resource.data.version}
  </p><TagList tags={resource.data.tags} linked={false} /><div class="resource-actions">
    {
      hasFile && (
        <a class="button" href={resource.data.fileUrl} download>
          下载站内文件
        </a>
      )
    }{
      hasExternal && (
        <a
          class="button"
          href={resource.data.externalUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          访问外部资源
        </a>
      )
    }{!hasFile && !hasExternal && <span class="muted">演示条目，暂未提供下载地址</span>}
  </div>
</article>
