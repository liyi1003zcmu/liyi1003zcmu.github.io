---
import type { CollectionEntry } from 'astro:content';
interface Props {
  course: CollectionEntry<'courses'>;
}
const { course } = Astro.props;
---

<article class="card" data-pagefind-filter="type:课程">
  <div class="card-cover" aria-hidden="true">{course.data.shortTitle}</div><p class="eyebrow">
    演示课程 · {course.data.status}
  </p><h3><a href={`/courses/${course.data.slug}/`}>{course.data.title}</a></h3><p
    class="card-meta"
  >
    {course.data.semester} · {course.data.audience}
  </p><p class="card-description">{course.data.description}</p>
</article>
