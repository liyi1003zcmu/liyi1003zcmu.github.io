---
import type { CollectionEntry } from 'astro:content';
import { entrySlug } from '@/lib/content';
interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
---

<article class="card" data-pagefind-filter="type:项目">
  <div class="card-cover" aria-hidden="true">{project.data.projectType}</div><p class="eyebrow">
    示例项目 · {project.data.status}
  </p><h3><a href={`/projects/${entrySlug(project.id)}/`}>{project.data.title}</a></h3><p
    class="card-description"
  >
    {project.data.description}
  </p>
</article>
