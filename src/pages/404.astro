---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到" description="请求的页面不存在。" noIndex
  ><div class="container page-section">
    <div class="empty-state">
      <p class="eyebrow">404</p><h1>没有找到这个页面</h1><p>地址可能已更改，或内容尚未发布。</p><div
        class="button-row"
        style="justify-content:center"
      >
        <a class="button button-primary" href="/">返回首页</a><a class="button" href="/search/"
          >搜索站内内容</a
        >
      </div>
    </div>
  </div></BaseLayout
>
