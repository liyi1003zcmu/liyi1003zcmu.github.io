---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import SearchBox from '@/components/SearchBox.astro';
---

<BaseLayout title="站内搜索" description="搜索课程、教学资源、博客与项目。"
  ><div class="container">
    <Breadcrumbs items={[{ label: '站内搜索' }]} /><header class="page-header">
      <p class="eyebrow">静态搜索</p><h1>搜索站内内容</h1><p>
        索引在正式构建后由 Pagefind 生成，中文关键词在访客设备上完成匹配。
      </p>
    </header><SearchBox />
  </div></BaseLayout
>
