---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import CourseCard from '@/components/CourseCard.astro';
import BlogCard from '@/components/BlogCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import ResourceItem from '@/components/ResourceItem.astro';
import { publishedPosts } from '@/lib/content';
import { siteConfig } from '@/config/site';
const [courses, posts, resources, projects] = await Promise.all([
  getCollection('courses'),
  getCollection('blog'),
  getCollection('resources', ({ data }) => data.public),
  getCollection('projects'),
]);
const featuredCourses = courses
  .filter(({ data }) => data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const latestPosts = publishedPosts(posts).slice(0, 3);
const latestResources = resources
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const featuredProjects = projects
  .filter(({ data }) => data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout title={siteConfig.name}>
  <section class="hero">
    <div class="container">
      <p class="hero-kicker">说话 · 实践 · 记录</p>
      <h1>{siteConfig.name}</h1>
      <p class="hero-lead">
        {
          siteConfig.description
        }。这是我的个人工作空间记录。除了课程材料分发外，也会记录与教学相关的学习、实践与心得。
      </p>
      <div class="button-row">
        <a class="button button-primary" href="/courses/">浏览课程</a>
        <a class="button" href="/resources/">教学资源</a>
        <a class="button" href="/blog/">个人博客</a>
      </div>
    </div>
  </section>
  <section class="page-section">
    <div class="container grid grid-2">
      <div>
        <p class="eyebrow">网站介绍</p>
        <h2>与教学有关的学习、实践与心得</h2>
        <p>
          一直想做一个个人小站，无奈行动力不强，毛坯房至今。终于AI工具的出现让我在2026暑假开始的时候下定决心对这间毛坯房进行装修。这里主要用于课程教学资源的发放，同时记录自己对于教学工作的所思所想，希望在退休的时候回头看，能够看到一个不一样的我。
        </p>
      </div>
      <div class="card">
        <p class="eyebrow">作者简介</p>
        <h2>{siteConfig.author}</h2>
        <p>小小教书匠</p>
        <p><a href="/about/">关于我 →</a></p>
      </div>
    </div>
  </section>
  <section class="page-section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">主要课程</p>
          <h2>很杂的课程列表</h2>
        </div>
        <a href="/courses/">全部课程</a>
      </div>
      <div class="grid grid-3">
        {featuredCourses.map((course) => <CourseCard {course} />)}
      </div>
    </div>
  </section>
  <section class="page-section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">最新博客</p>
          <h2>随想随录</h2>
        </div>
        <a href="/blog/">全部文章</a>
      </div>
      <div class="grid grid-3">
        {latestPosts.map((post) => <BlogCard {post} />)}
      </div>
    </div>
  </section>
  <section class="page-section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">最新资源</p>
          <h2>课件、代码与实验资料</h2>
        </div>
        <a href="/resources/">筛选资源</a>
      </div>
      {latestResources.map((resource) => <ResourceItem {resource} />)}
    </div>
  </section>
  <section class="page-section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">项目与成果</p>
          <h2>记录目标、过程与下一步</h2>
        </div>
        <a href="/projects/">全部项目</a>
      </div>
      <div class="grid grid-3">
        {featuredProjects.map((project) => <ProjectCard {project} />)}
      </div>
    </div>
  </section>
  <section class="page-section">
    <div class="container">
      <div class="section-heading">
        <div><p class="eyebrow">常用入口</p><h2>从这里开始</h2></div>
      </div><div class="grid grid-3">
        <a class="card" href="/blog/archive/"><h3>文章归档</h3><p>按年份回顾博客记录。</p></a><a
          class="card"
          href="/search/"><h3>站内搜索</h3><p>搜索课程、资源、博客和项目。</p></a
        ><a class="card" href="/rss.xml"><h3>RSS 订阅</h3><p>使用阅读器跟踪最新文章。</p></a>
        <a class="card" href="/library/">
          <h3>文献资料</h3>
          <p>浏览论文、笔记和个人整理资料。</p>
        </a>
      </div>
    </div>
  </section></BaseLayout
>
