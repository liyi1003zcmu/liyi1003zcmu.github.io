---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CourseCard from '@/components/CourseCard.astro';
const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="课程教学" description="课程介绍、教学目标、章节安排与配套资源。"
  ><div class="container">
    <Breadcrumbs items={[{ label: '课程教学' }]} /><header class="page-header">
      <p class="eyebrow">课程教学</p>
      <h1>我的课程列表</h1><p>
          这些都是我正在上的课，所有的课程资料、课件、实验、参考资料等都会整理发布在此。希望能对大家有所帮助，也欢迎大家提出意见和建议。
      </p>
    </header><div class="grid grid-3">{courses.map((course) => <CourseCard {course} />)}</div>
  </div></BaseLayout
>
