---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CourseCard from '@/components/CourseCard.astro';
const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="课程教学" description="课程介绍、教学目标、章节安排与配套资源。"
  ><div class="container">
    <Breadcrumbs items={[{ label: '课程教学' }]} /><header class="page-header">
      <p class="eyebrow">课程教学</p><h1>课程与学习路径</h1><p>
        以下均为演示课程，用于展示长期维护课程说明、教学进度和配套资料的方式。
      </p>
    </header><div class="grid grid-3">{courses.map((course) => <CourseCard {course} />)}</div>
  </div></BaseLayout
>
