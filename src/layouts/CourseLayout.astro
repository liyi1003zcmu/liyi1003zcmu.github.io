---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
interface Props {
  title: string;
  description: string;
  status: string;
  semester: string;
  updatedDate: Date;
}
const { title, description, status, semester, updatedDate } = Astro.props;
---

<BaseLayout {title} {description}
  ><div class="container">
    <Breadcrumbs items={[{ label: '课程', href: '/courses/' }, { label: title }]} /><header
      class="page-header"
    >
      <p class="eyebrow">演示课程 · {status}</p><h1 data-pagefind-meta="title">{title}</h1><p>
        {description}
      </p><p class="card-meta">{semester} · 更新于 {updatedDate.toLocaleDateString('zh-CN')}</p>
    </header><article class="prose"><slot /></article>
  </div></BaseLayout
>
